{
  "expo": {
    "name": "Maranatha-movil",
    "slug": "maranatha-movil",
    "platforms": ["android"],
    "version": "3.2.1",
    "orientation": "default",
    "icon": "./assets/icons/adaptive-icon.png",
    "scheme": "maranathamovil",
    "userInterfaceStyle": "automatic",
    "runtimeVersion": "2",
    "updates": {
      "url": "https://u.expo.dev/43ce48e7-b307-409d-baca-1aa3fc4eb7a6",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/icons/adaptive-icon.png",
        "backgroundImage": "./assets/icons/adaptive-icon.png",
        "monochromeImage": "./assets/icons/adaptive-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.novatech.maranathamovil"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icons/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-sqlite",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          },
          "ios": {
            "infoPlist": {
              "NSAppTransportSecurity": {
                "NSAllowsArbitraryLoads": true
              }
            }
          }
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "43ce48e7-b307-409d-baca-1aa3fc4eb7a6"
      }
    }
  }
}
